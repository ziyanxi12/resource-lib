# ── 服务端口 ──────────────────────────────────────────────────────
PORT=8009

# ── 数据库 ────────────────────────────────────────────────────────
# 方式一（优先）：直接指定完整连接串
#   本地开发用 SQLite（无需安装 MySQL）：
#     DB_URL=sqlite:///./dev.db
#   生产环境用 MySQL：
#     DB_URL=mysql+pymysql://user:password@host:3306/dbname
# 方式二：留空 DB_URL，分项填写下方 MySQL 配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=resource_lib
DB_USER=root
DB_PASSWORD=

# ── 文件存储 ──────────────────────────────────────────────────────
# 所有上传文件和预置 JSON 的根目录，子目录结构：
#   component/   组件库文件（component_map.json、各 component_index.json、hex 文件）
#   icon/        SVG 图标数据（icons.json）
#   illus/       插画数据（illus.json）
#   template/    模版数据（templates.json 及上传的模版文件）
#   image/       上传的图片文件
FILE_ROOT_DIR=./storage

# 组件库映射表路径，记录所有组件库的 indexPath，初始化时按此遍历
COMPONENT_MAP_FILE=./storage/component/component_map.json

# ── 日志 ─────────────────────────────────────────────────────────
# 日志目录，每天生成一个新文件（如 app.2026-06-27.txt），保留 30 天
LOG_DIR=./logs
# 日志级别：DEBUG（打印向量文本构建详情）/ INFO / WARNING / ERROR
# 生产建议 INFO；排查向量搜索问题时改为 DEBUG
LOG_LEVEL=INFO

# ── 翻译文件 ──────────────────────────────────────────────────────
# 组件属性值中文翻译表，用于 build_component_text；文件不存在时打印 WARNING 并跳过翻译
TRANSLATION_FILE=./storage/component/value_translations.json

# ── Mock 模式 ─────────────────────────────────────────────────────
# true：不调用任何外部 API，返回内置模拟数据，适合本地开发
# false：使用下方配置的真实外部 API 地址
USE_MOCK=true

# ── 外部 API 地址（USE_MOCK=false 时生效）────────────────────────
# 设计工具服务，用于同步组件库数据（/api/component/sync 接口调用链）：
#   1. GET_VERSION_API_URL  查询指定 fileKey 的最新版本号
#   2. GET_FILE_API_URL     按 fileKey + versionId 下载组件库 .pix 源文件
#   3. SPLIT_API_URL        将 .pix 文件拆解为 component_index.json + hex 文件
GET_VERSION_API_URL=http://127.0.0.1:xxxx/api/getVersion
GET_FILE_API_URL=http://127.0.0.1:xxxx/api/getFile
SPLIT_API_URL=http://127.0.0.1:3103/split

# 图标服务，用于同步 SVG/插画数据（/api/icon/sync 接口调用链）：
#   ICON_API_URL  拉取全量图标列表，返回 [{id, name, englishName, category, description}]
ICON_API_URL=http://127.0.0.1:xxxx/api/icon

# ── 向量服务 ──────────────────────────────────────────────────────
# 向量库管理服务地址，用于组件和图标数据的语义搜索入库
# VECTOR_SERVICE_ENABLED=false 时跳过向量入库，仅写关系型数据库
VECTOR_SERVICE_URL=http://localhost:8000
VECTOR_SERVICE_ENABLED=false
